<% layout("/layout/boilerplate") %>

<div class="container mt-5">

<h2 class="mb-4">Edit Car</h2>

<form action="/admin/cars/<%= car._id %>?_method=PUT" method="POST">

<div class="mb-3">
<label>Title</label>
<input class="form-control" name="title" value="<%= car.title %>">
</div>

<div class="mb-3">
<label>Brand</label>
<input class="form-control" name="brand" value="<%= car.brand %>">
</div>

<div class="mb-3">
<label>Model</label>
<input class="form-control" name="model" value="<%= car.model %>">
</div>

<div class="mb-3">
<label>Price Per Day</label>
<input class="form-control" name="pricePerDay" value="<%= car.pricePerDay %>">
</div>

<div class="mb-3">
<label>Location</label>
<input class="form-control" name="location" value="<%= car.location %>">
</div>

<div class="mb-3">
<label>Image URL</label>
<input class="form-control" name="imageUrl" value="<%= car.image.url %>">
</div>

<div class="mb-3">
<label>Description</label>
<textarea class="form-control" name="description"><%= car.description %></textarea>
</div>

<button class="btn btn-primary">
Update Car
</button>

</form>

</div>